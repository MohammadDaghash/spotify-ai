VITE_SPOTIFY_CLIENT_ID=your_spotify_client_id

# The app callback route is /callback.
# Production must be added exactly in Spotify Developer Dashboard:
# https://spotify-ai-sooty.vercel.app/callback
#
# For local development, use the exact Vite origin you are running:
# http://127.0.0.1:5173/callback
# or
# http://127.0.0.1:5174/callback
VITE_SPOTIFY_REDIRECT_URI=https://spotify-ai-sooty.vercel.app/callback

# Optional. Leave empty in public frontend-only demo mode.
VITE_ML_API_URL=

# Optional token endpoint override. Usually not needed for PKCE.
VITE_TOKEN_ENDPOINT=https://accounts.spotify.com/api/token

# Server-only public listening sync.
# Add these in Vercel Project Settings -> Environment Variables.
# Do not prefix these with VITE_ and do not expose them in frontend code.
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_optional_for_confidential_auth
SPOTIFY_REFRESH_TOKEN=your_server_side_refresh_token

# Vercel Blob read/write token. Created automatically when you attach
# a Vercel Blob store to this project.
BLOB_READ_WRITE_TOKEN=your_vercel_blob_read_write_token

# Optional. Used by Vercel Cron as the Authorization header.
# If configured, Vercel sends: Authorization: Bearer <CRON_SECRET>
CRON_SECRET=generate_a_random_secret_at_least_16_chars

# Optional custom blob pathname for the public sync JSON.
SPOTIFY_SYNC_STORAGE_PATH=spotify-ai/public-listening/recent-plays.json
